<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen icon: Edge Impulse "ei" wordmark in white on a dark background.
  Shown at launch via windowSplashScreenAnimatedIcon.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="48dp"
        android:height="48dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#0E0E10" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item
        android:width="40dp"
        android:height="40dp"
        android:gravity="center">
        <!-- "ei" wordmark scaled to 24x24 viewport -->
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="108"
            android:viewportHeight="108">
            <!-- lowercase "e" -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M30,58 a14,14 0 1,1 26,8 l-5,-3 a9,9 0 1,0 -16,-6 h18 a14,14 0 0,1 -23,1 Z" />
            <!-- lowercase "i" stem -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M62,46 h6 v26 h-6 Z" />
            <!-- "i" dot -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M65,38 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
        </vector>
    </item>
</layer-list>
